@using CP_Sight.Core.Models
@using CP_Sight.Web.Services
@inject ReportGenerator ReportGenerator
@inject IJSRuntime JS

<MudPaper Elevation="2" Class="pa-6">
    <MudGrid>
        <!-- Risk Score Display -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="0" Class="text-center">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Risk Assessment</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <div Class="d-flex justify-center align-center" Style="height: 150px;">
                        <div Class="position-relative d-inline-flex justify-center align-center">
                            <MudProgressCircular Value="@Result.Assessment.RiskScore" 
                                                 Size="Size.Large"
                                                 Color="@GetRiskColor(Result.Assessment.OverallRisk)"
                                                 StrokeWidth="8"
                                                 Class="ma-4" />
                            <MudText Typo="Typo.h5" Class="position-absolute">@Result.Assessment.RiskScore</MudText>
                        </div>
                    </div>
                    <MudChip T="string" Color="@GetRiskColor(Result.Assessment.OverallRisk)" Size="Size.Medium">
                        @Result.Assessment.OverallRisk.ToUpper() RISK
                    </MudChip>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Feature Breakdown -->
        <MudItem xs="12" md="8">
            <MudText Typo="Typo.h6" Class="mb-4">Feature Analysis</MudText>
            <MudTable Items="@_featureRows" Dense="true" Hover="true" Style="width: 100%;">
                <HeaderContent>
                    <MudTh>Feature</MudTh>
                    <MudTh>Value</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Feature">@context.Name</MudTd>
                    <MudTd DataLabel="Value">@context.Value</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)">
                            @context.Status
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>

        <!-- Recommendations -->
        <MudItem xs="12">
            <MudText Typo="Typo.h6" Class="mb-4">Recommendations</MudText>
            <MudList T="string" Dense="true">
                @foreach (var recommendation in Result.Assessment.Recommendations)
                {
                    <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Primary">
                        @recommendation
                    </MudListItem>
                }
            </MudList>
        </MudItem>

        <!-- Actions -->
        <MudItem xs="12">
            <MudDivider Class="my-4" />
            <MudButtonGroup Variant="Variant.Outlined">
                <MudButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.Refresh" OnClick="OnReset">
                    New Analysis
                </MudButton>
                <MudButton Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download"
                           OnClick="DownloadReport" Disabled="@_isGeneratingPdf">
                    @if (_isGeneratingPdf)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Generating PDF...</span>
                    }
                    else
                    {
                        <span>Download Report</span>
                    }
                </MudButton>
            </MudButtonGroup>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter]
    public AnalysisResult Result { get; set; } = null!;

    [Parameter]
    public EventCallback OnReset { get; set; }

    private bool _isGeneratingPdf;

    private async Task DownloadReport()
    {
        _isGeneratingPdf = true;
        StateHasChanged();

        try
        {
            var pdfBytes = await ReportGenerator.GeneratePdfAsync(Result);
            var base64 = Convert.ToBase64String(pdfBytes);
            var fileName = $"CP-sight-Report-{Result.Id}.pdf";
            await JS.InvokeVoidAsync("cpSight.downloadFile", fileName, base64, "application/pdf");
        }
        finally
        {
            _isGeneratingPdf = false;
            StateHasChanged();
        }
    }

    private List<FeatureRow> _featureRows => new()
    {
        new FeatureRow(
            "Movement Complexity",
            Result.Assessment.Breakdown.MovementComplexity.Value.ToString("F3"),
            Result.Assessment.Breakdown.MovementComplexity.Status
        ),
        new FeatureRow(
            "Movement Variability",
            Result.Assessment.Breakdown.MovementVariability.Value.ToString("F3"),
            Result.Assessment.Breakdown.MovementVariability.Status
        ),
        new FeatureRow(
            "Fidgety Movements",
            Result.Assessment.Breakdown.FidgetyMovements.Value.ToString("F3"),
            Result.Assessment.Breakdown.FidgetyMovements.Status
        ),
        new FeatureRow(
            "Symmetry",
            Result.Assessment.Breakdown.Symmetry.Value.ToString("F3"),
            Result.Assessment.Breakdown.Symmetry.Status
        )
    };

    private record FeatureRow(string Name, string Value, string Status);

    private Color GetRiskColor(string risk) => risk switch
    {
        "low" => Color.Success,
        "medium" => Color.Warning,
        "high" => Color.Error,
        _ => Color.Default
    };

    private Color GetStatusColor(string status) => status switch
    {
        "normal" => Color.Success,
        "borderline" => Color.Warning,
        "abnormal" => Color.Error,
        _ => Color.Default
    };
}